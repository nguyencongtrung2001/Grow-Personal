datasource db {
  provider = "postgresql"
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["debian-openssl-3.0.x"]
}

// ==========================================
// ENUMS
// ==========================================

enum AuthProvider {
  GOOGLE
  GITHUB
  EMAIL
}

enum ChallengeStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

enum MediaType {
  IMAGE
  VIDEO
  AUDIO
}

enum VocabMiniMode {
  CARD_FLIP
  QUIZ
  SPEED_MATCH
  DICTATION
}

enum DayStatus {
  COMPLETED
  SKIPPED
  FAILED
}

enum WordType {
  NOUN
  VERB
  ADJECTIVE
  ADVERB
  PREPOSITION
  CONJUNCTION
  PHRASE
  OTHER
}
enum UserRole {
  USER
  ADMIN
}
// ==========================================
// 1. Model: User
// ==========================================

model User {
  id         String       @id @default(uuid()) @db.Uuid
  email      String       @unique
  name       String?
  avatarUrl  String?
  role       UserRole     @default(USER) // Mặc định là USER
  provider   AuthProvider @default(GOOGLE)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  folders    Folder[]     @relation(name: "FolderToUser")
  notes      Note[]       @relation(name: "NoteToUser")
  vocabDecks VocabDeck[]  @relation(name: "UserToVocabDeck")
  challenges Challenge[]  @relation(name: "ChallengeToUser")
  vocabMinis VocabMini[]  @relation(name: "UserToVocabMini")

  @@map("users")
}

// ==========================================
// 2. Model: Folder & Note
// ==========================================

model Folder {
  id        String   @id @default(uuid()) @db.Uuid
  emoji     String   @default("📂")
  name      String
  userId    String   @db.Uuid
  user      User     @relation(name: "FolderToUser", fields: [userId], references: [id], onDelete: Cascade)
  notes     Note[]   @relation(name: "FolderToNote")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId], map: "idx_folders_user")
  @@map("folders")
}

model Note {
  id        String   @id @default(uuid()) @db.Uuid
  title     String
  content   String   @db.Text
  folderId  String?  @db.Uuid // Tối ưu UX: Hỗ trợ ghi chú nhanh chưa phân loại (Uncategorized)
  folder    Folder?  @relation(name: "FolderToNote", fields: [folderId], references: [id], onDelete: SetNull)
  userId    String   @db.Uuid
  user      User     @relation(name: "NoteToUser", fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([folderId], map: "idx_notes_folder")
  @@index([userId], map: "idx_notes_user")
  @@map("notes")
}

// ==========================================
// 3. Model: VocabDeck & VocabCard
// ==========================================

model VocabDeck {
  id          String      @id @default(uuid()) @db.Uuid
  title       String
  description String?     @db.VarChar(500)
  themeColor  String      @default("text-sky-600")
  locale      String      @default("en-US") @db.VarChar(10) // Cấu hình Speech API Language
  userId      String      @db.Uuid
  user        User        @relation(name: "UserToVocabDeck", fields: [userId], references: [id], onDelete: Cascade)
  cards       VocabCard[] @relation(name: "VocabCardToVocabDeck")
  vocabMinis  VocabMini[] @relation(name: "VocabDeckToVocabMini")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([userId], map: "idx_vocab_decks_user")
  @@map("vocab_decks")
}

model VocabCard {
  id         String    @id @default(uuid()) @db.Uuid
  deckId     String    @db.Uuid
  deck       VocabDeck @relation(name: "VocabCardToVocabDeck", fields: [deckId], references: [id], onDelete: Cascade)
  word       String
  type       WordType  @default(OTHER)
  definition String    @db.VarChar(1000)
  isStarred  Boolean   @default(false)
  usage      String?   @db.VarChar(1500)
  imageUrl   String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([deckId], map: "idx_vocab_cards_deck")
  @@index([word], map: "idx_vocab_cards_word")
  @@map("vocab_cards")
}

// ==========================================
// 4. Model: Challenge, HistoryLog & MediaFile
// ==========================================

model Challenge {
  id                 String          @id @default(uuid()) @db.Uuid
  slug               String          @unique
  title              String
  description        String?         @db.VarChar(1000)
  category           String
  status             ChallengeStatus @default(ACTIVE)
  totalDays          Int             @default(30)
  completedDaysCount Int             @default(0)
  streak             Int             @default(0)
  progress           Int             @default(0)
  startDate          DateTime        @default(now())
  estimatedEndDate   DateTime
  userId             String          @db.Uuid
  user               User            @relation(name: "ChallengeToUser", fields: [userId], references: [id], onDelete: Cascade)
  historyLogs        HistoryLog[]    @relation(name: "ChallengeToHistoryLog")
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  @@index([userId], map: "idx_challenges_user")
  @@index([status, userId], map: "idx_challenges_status_user") // Phục vụ query nhanh màn hình Dashboard
  @@map("challenges")
}

model HistoryLog {
  id          String      @id @default(uuid()) @db.Uuid
  challengeId String      @db.Uuid
  challenge   Challenge   @relation(name: "ChallengeToHistoryLog", fields: [challengeId], references: [id], onDelete: Cascade)
  day         Int
  loggedDate  DateTime    @db.Date // Giải quyết dứt điểm sai lệch Timezone khi User check-in
  status      DayStatus   @default(FAILED)
  moodId      String?     @db.Uuid
  mood        Mood?       @relation(name: "HistoryLogToMood", fields: [moodId], references: [id], onDelete: SetNull)
  note        String?     @db.Text
  mediaFiles  MediaFile[] @relation(name: "HistoryLogToMediaFile")
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([challengeId, day])
  @@index([challengeId], map: "idx_history_logs_challenge")
  @@index([moodId], map: "idx_history_logs_mood")
  @@map("history_logs")
}

model MediaFile {
  id        String     @id @default(uuid()) @db.Uuid
  logId     String     @db.Uuid
  log       HistoryLog @relation(name: "HistoryLogToMediaFile", fields: [logId], references: [id], onDelete: Cascade)
  type      MediaType  @default(IMAGE)
  url       String
  name      String?
  createdAt DateTime   @default(now())

  @@index([logId], map: "idx_media_files_log")
  @@map("media_files")
}

// ==========================================
// 5. Model: Mood
// ==========================================

model Mood {
  id          String       @id @default(uuid()) @db.Uuid
  name        String       @unique
  icon        String
  historyLogs HistoryLog[] @relation(name: "HistoryLogToMood")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("moods")
}

// ==========================================
// 6. Model: VocabMini
// ==========================================

model VocabMini {
  id           String        @id @default(uuid()) @db.Uuid
  userId       String        @db.Uuid
  user         User          @relation(name: "UserToVocabMini", fields: [userId], references: [id], onDelete: Cascade)
  deckId       String        @db.Uuid
  deck         VocabDeck     @relation(name: "VocabDeckToVocabMini", fields: [deckId], references: [id], onDelete: Cascade)
  gameMode     VocabMiniMode
  score        Int           @default(0)
  accuracy     Float         @default(0)
  duration     Int
  correctCount Int           @default(0)
  wrongCount   Int           @default(0)
  history      Json?         // Lưu ý: Validate format mảng này chặt chẽ bằng Zod ở tầng Service
  createdAt    DateTime      @default(now())

  @@index([userId], map: "idx_vocab_mini_user")
  @@index([deckId], map: "idx_vocab_mini_deck")
  @@index([createdAt], map: "idx_vocab_mini_date")
  @@map("vocab_minis")
} 